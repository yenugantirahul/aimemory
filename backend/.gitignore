```gitignore
# Dependencies
node_modules/

# Build output
dist/
build/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# Coverage
coverage/

# Temporary files
.tmp/
temp/

# Drizzle generated metadata (keep migrations)
drizzle/meta/

# Turbo
.turbo/

# ESLint cache
.eslintcache
```

